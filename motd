#!/usr/bin/env bash
# motd

set -euo pipefail

VERSION="0.1.0"

# ──────────────────────────────────────────────────────────────────────────────
# Terminal colors
# ──────────────────────────────────────────────────────────────────────────────
if [ -t 1 ]; then
	C_RED=$'\033[0;31m'
	C_GREEN=$'\033[0;32m'
	C_YELLOW=$'\033[0;33m'
	C_BLUE=$'\033[0;34m'
	C_MAGENTA=$'\033[0;35m'
	C_WHITE=$'\033[0;37m'
	C_BOLD=$'\033[1m'
	C_RESET=$'\033[0m'
else
	C_RED=""
	C_GREEN=""
	C_YELLOW=""
	C_BLUE=""
	C_MAGENTA=""
	C_WHITE=""
	C_BOLD=""
	C_RESET=""
fi
C_WARN="${C_BOLD}${C_YELLOW}"

FULL_MODE=0
case "${1:-}" in
--full | -f)
	FULL_MODE=1
	;;
esac

# ──────────────────────────────────────────────────────────────────────────────
# Check optional tools
# ──────────────────────────────────────────────────────────────────────────────
missing_pkgs=""
# CPU temperature support disabled.
# need_sensors_detect=0
command -v figlet >/dev/null 2>&1 || missing_pkgs="$missing_pkgs figlet"
# command -v sensors >/dev/null 2>&1 || {
# 	missing_pkgs="$missing_pkgs lm-sensors"
# 	need_sensors_detect=1
# }
command -v curl >/dev/null 2>&1 || missing_pkgs="$missing_pkgs curl"

if [ -n "$missing_pkgs" ] && [ -t 0 ]; then
	printf "%sOptional tools not installed:%s %s\n" "$C_YELLOW" "$C_RESET" "$missing_pkgs"
	printf "Install now? [y/N] "
	read -r _answer </dev/tty
	if [ "$_answer" = "y" ] || [ "$_answer" = "Y" ]; then
		sudo apt install -y $missing_pkgs
		# [ "$need_sensors_detect" = "1" ] && sudo sensors-detect --auto
	fi
	printf "\n"
fi

# ──────────────────────────────────────────────────────────────────────────────
# Distro info
# ──────────────────────────────────────────────────────────────────────────────
DISTRIB_DESCRIPTION=""
if command -v lsb_release >/dev/null 2>&1; then
	DISTRIB_DESCRIPTION=$(lsb_release -s -d 2>/dev/null) || true
fi
if [ -z "$DISTRIB_DESCRIPTION" ] && [ -r /etc/os-release ]; then
	DISTRIB_DESCRIPTION=$(awk -F= '/^PRETTY_NAME=/{ gsub(/^"|"$/, "", $2); print $2; exit }' /etc/os-release)
fi
if [ -z "$DISTRIB_DESCRIPTION" ] && [ -r /etc/lsb-release ]; then
	DISTRIB_DESCRIPTION=$(awk -F= '/^DISTRIB_DESCRIPTION=/{ gsub(/^"|"$/, "", $2); print $2; exit }' /etc/lsb-release)
fi
[ -z "$DISTRIB_DESCRIPTION" ] && DISTRIB_DESCRIPTION="Linux"

# ──────────────────────────────────────────────────────────────────────────────
# Gather stats
# ──────────────────────────────────────────────────────────────────────────────
cols=${COLUMNS:-$(tput cols 2>/dev/null || echo 80)}
date=$(date +"%Y-%m-%d %H:%M:%S")
kernel=$(uname -r)
cpu_cores=$(nproc 2>/dev/null || grep -c '^processor' /proc/cpuinfo)
cpu_load=$(awk '{ printf "%.2f (1m)  %.2f (5m)  %.2f (15m)", $1, $2, $3 }' /proc/loadavg)
load_pct_raw=$(awk -v c="$cpu_cores" '{ if (c < 1) c = 1; p = int($1 / c * 100); print p }' /proc/loadavg)
load_pct=$load_pct_raw
[ "$load_pct" -gt 100 ] && load_pct=100
cpu_overload=""
[ "$load_pct_raw" -gt 100 ] && cpu_overload=" (overload: ${load_pct_raw}%)"
cpu_processes=$(ps -e --no-headers | wc -l)
memory_usage=$(free -b | awk '/Mem:/  { printf "%.0f%% (%.2f/%.2f GiB)", ($3 / $2) * 100, $3 / (1024 * 1024 * 1024), $2 / (1024 * 1024 * 1024); }')
mem_pct=$(free -b | awk '/Mem:/  { printf "%d", ($3 / $2) * 100 }')
disk_usage=$(df -B1 / | awk 'NR==2 { printf "%.0f%% (%.2f/%.2f GiB)", ($3 / $2) * 100, $3 / (1024 * 1024 * 1024), $2 / (1024 * 1024 * 1024); }')
disk_pct=$(df -B1 / | awk 'NR==2 { printf "%d", ($3 / $2) * 100 }')
swap_usage=""
swap_pct=0
users_logged=""
users_count=0
if [ "$FULL_MODE" = "1" ]; then
	swap_usage=$(free -b | awk '/Swap:/ { if ($2 == 0) { printf "0%% (0.00/0.00 GiB)"; } else { printf "%.0f%% (%.2f/%.2f GiB)", ($3 / $2) * 100, $3 / (1024 * 1024 * 1024), $2 / (1024 * 1024 * 1024); } }')
	swap_pct=$(free -b | awk '/Swap:/ { if ($2 == 0) print 0; else printf "%d", ($3 / $2) * 100 }')
	users_logged=$(who | awk '{ print $1 }' | sort -u | awk 'BEGIN { first = 1 } { if (!first) printf ", "; printf "%s", $1; first = 0 } END { if (first) printf "none" }')
	users_count=$(who | awk '{ print $1 }' | sort -u | wc -l | awk '{ print $1 }')
fi
uptime_str=$(uptime -p)
private_ip=$(hostname -I 2>/dev/null | awk '{ print $1 }') || true

docker_running=""
if [ "$FULL_MODE" = "1" ] && command -v docker >/dev/null 2>&1; then
	docker_running=$(docker ps -q 2>/dev/null | wc -l) || true
fi

# CPU temperature section intentionally disabled.
# cpu_temp=""
# if command -v sensors >/dev/null 2>&1; then
# 	cpu_temp=$(sensors 2>/dev/null | awk '
# 		/Core 0:|Package id 0:|Tdie:/ {
# 			match($0, /[+][0-9]+\.[0-9]+/)
# 			if (RSTART) { printf "%.1f\302\260C", substr($0, RSTART+1, RLENGTH-1)+0; exit }
# 		}')
# fi
# if [ -z "$cpu_temp" ] && [ -r /sys/class/thermal/thermal_zone0/temp ]; then
# 	cpu_temp=$(cat /sys/class/thermal/thermal_zone0/temp 2>/dev/null | awk 'NF { printf "%.1f\302\260C", $1 / 1000 }')
# fi

# Opt-in via MOTD_ENABLE_PUBLIC_IP=1, cached for 3 hours.
public_ip=""
if [ "$FULL_MODE" = "1" ] && [ "${MOTD_ENABLE_PUBLIC_IP:-0}" = "1" ] && command -v curl >/dev/null 2>&1; then
	public_ip_cache_file=""
	if [ -n "${XDG_CACHE_HOME:-}" ]; then
		public_ip_cache_file="${XDG_CACHE_HOME}/motd-public-ip"
	elif [ -n "${HOME:-}" ]; then
		public_ip_cache_file="${HOME}/.cache/motd-public-ip"
	else
		public_ip_cache_file="/tmp/motd-${USER:-$(id -u)}-public-ip"
	fi

	public_ip_cache_dir=$(dirname "$public_ip_cache_file")
	[ -d "$public_ip_cache_dir" ] || mkdir -p "$public_ip_cache_dir" 2>/dev/null

	now_ts=$(date +%s 2>/dev/null)
	cache_mtime=""
	if [ -r "$public_ip_cache_file" ]; then
		cache_mtime=$(stat -c %Y "$public_ip_cache_file" 2>/dev/null) || true
	fi

	if [ -n "$now_ts" ] && [ -n "$cache_mtime" ] && [ $((now_ts - cache_mtime)) -le 10800 ]; then
		public_ip=$(cat "$public_ip_cache_file" 2>/dev/null) || true
	else
		[ -n "$cache_mtime" ] && rm -f "$public_ip_cache_file" 2>/dev/null
		public_ip=$(curl -fsS --connect-timeout 3 --max-time 5 https://ifconfig.me 2>/dev/null) || true
		[ -n "$public_ip" ] && printf "%s\n" "$public_ip" >"$public_ip_cache_file" 2>/dev/null
	fi
fi

last_login=""
if command -v lastlog >/dev/null 2>&1; then
	last_login=$(lastlog -u "${USER:-$(id -un)}" 2>/dev/null | tail -1 | awk '{ $1=""; sub(/^ */, ""); print }') || true
fi

# Opt-in via MOTD_ENABLE_FAILED_LOGINS=1.
failed_logins=""
if [ "$FULL_MODE" = "1" ] && [ "${MOTD_ENABLE_FAILED_LOGINS:-0}" = "1" ] && command -v journalctl >/dev/null 2>&1; then
	failed_logins=$(journalctl _COMM=sshd --since "240 hours ago" 2>/dev/null | grep -c "Failed password") || true
fi

updates_total=""
updates_security=""
if [ -r /var/lib/update-notifier/updates-available ]; then
	updates_total_count=$(awk '
		BEGIN { IGNORECASE=1 }
		$0 ~ /^[[:space:]]*[0-9]+[[:space:]]/ && $0 ~ /updates?/ && $0 !~ /security/ {
			for (i = 1; i <= NF; i++) {
				if ($i ~ /^[0-9]+$/) { print $i; exit }
			}
		}
	' /var/lib/update-notifier/updates-available)

	updates_security_count=$(awk '
		BEGIN { IGNORECASE=1 }
		$0 ~ /^[[:space:]]*[0-9]+[[:space:]]/ && $0 ~ /security/ {
			for (i = 1; i <= NF; i++) {
				if ($i ~ /^[0-9]+$/) { print $i; exit }
			}
		}
	' /var/lib/update-notifier/updates-available)

	if [ -n "$updates_total_count" ]; then
		updates_total="${updates_total_count} updates available"
	fi
	if [ -n "$updates_security_count" ] && [ "$updates_security_count" -gt 0 ] 2>/dev/null; then
		updates_security="${updates_security_count} security updates"
	fi
fi

# ──────────────────────────────────────────────────────────────────────────────
# Health summary
# ──────────────────────────────────────────────────────────────────────────────
health_state="OK"
health_reasons=""
if [ "$load_pct_raw" -gt 100 ]; then
	health_state="WARNING"
	health_reasons="${health_reasons}load "
fi
if [ "$mem_pct" -ge 90 ]; then
	health_state="WARNING"
	health_reasons="${health_reasons}memory "
fi
if [ "$FULL_MODE" = "1" ] && [ "$swap_pct" -ge 90 ]; then
	health_state="WARNING"
	health_reasons="${health_reasons}swap "
fi
if [ "$disk_pct" -ge 90 ]; then
	health_state="WARNING"
	health_reasons="${health_reasons}disk "
fi
if [ -n "$updates_security" ]; then
	health_state="WARNING"
	health_reasons="${health_reasons}security-updates "
fi

if [ "$health_state" = "WARNING" ]; then
	health_color=$C_YELLOW
else
	health_color=$C_GREEN
fi

if [ -n "$health_reasons" ]; then
	health_summary="$health_state (${health_reasons% })"
else
	health_summary="$health_state"
fi

# ──────────────────────────────────────────────────────────────────────────────
# Utilities
# ──────────────────────────────────────────────────────────────────────────────
# bar <percent> — fixed-width progress bar, red when >= 80%
bar() {
	_pct=$1
	_width=10
	_filled=$((_pct * _width / 100))
	[ "$_filled" -gt "$_width" ] && _filled=$_width
	[ "$_pct" -ge 80 ] && printf '%s' "$C_RED" || printf '%s' "$C_WHITE"
	printf '['
	_i=0
	while [ "$_i" -lt "$_filled" ]; do
		printf '#'
		_i=$((_i + 1))
	done
	while [ "$_i" -lt "$_width" ]; do
		printf ' '
		_i=$((_i + 1))
	done
	printf ']'
	printf '%s' "$C_RESET"
}

# ──────────────────────────────────────────────────────────────────────────────
# Banner
# ──────────────────────────────────────────────────────────────────────────────
printf "%s" "$C_MAGENTA"
if command -v figlet >/dev/null 2>&1; then
	printf "%s" "$C_BOLD"
	figlet -f small -w "$cols" "$(hostname)"
else
	printf "%s" "$C_BOLD"
	printf '%s\n' "$(hostname)"
fi
printf "%s" "$C_RESET"
printf "Welcome to %s%s%s (%s).\n" "$C_BLUE" "$DISTRIB_DESCRIPTION" "$C_RESET" "$kernel"

# ──────────────────────────────────────────────────────────────────────────────
# Output
# ──────────────────────────────────────────────────────────────────────────────
printf "%sSystem information as of:%s %s\n\n" "$C_GREEN" "$C_RESET" "$date"

printf "%sHealth:%s\t\t%s%s%s%s\n" "$C_GREEN" "$C_RESET" "$health_color" "$C_BOLD" "$health_summary" "$C_RESET"
# [ -n "$cpu_temp" ] && printf "%sCPU temp:%s\t%s\n" "$C_GREEN" "$C_RESET" "$cpu_temp"
printf "%sLoad avg:%s\t" "$C_GREEN" "$C_RESET" && bar "$load_pct"
printf " %s (%s processes)%s\n" "$cpu_load" "$cpu_processes" "$cpu_overload"
printf "%sMemory:%s\t\t" "$C_GREEN" "$C_RESET" && bar "$mem_pct"
printf " %s\n" "$memory_usage"
printf "%sDisk:%s\t\t" "$C_GREEN" "$C_RESET" && bar "$disk_pct"
printf " %s\n" "$disk_usage"
if [ "$FULL_MODE" = "1" ]; then
	printf "%sSwap:%s\t\t" "$C_GREEN" "$C_RESET" && bar "$swap_pct"
	printf " %s\n" "$swap_usage"
	[ -n "$docker_running" ] && printf "%sDocker:%s\t\t%s running containers\n" "$C_GREEN" "$C_RESET" "$docker_running"
	printf "%sUsers:%s\t\t%s (%s unique)\n" "$C_GREEN" "$C_RESET" "$users_logged" "$users_count"
fi
[ -n "$public_ip" ] && printf "%sPublic IP:%s\t%s\n" "$C_GREEN" "$C_RESET" "$public_ip"
[ "$FULL_MODE" = "1" ] && [ -n "$private_ip" ] && printf "%sPrivate IP:%s\t%s\n" "$C_GREEN" "$C_RESET" "$private_ip"
[ "$FULL_MODE" = "1" ] && [ -n "$last_login" ] && printf "%sLast login:%s\t%s\n" "$C_GREEN" "$C_RESET" "$last_login"
[ -n "$failed_logins" ] && printf "%sFailed logins:%s\t%s in the last 10 days\n" "$C_GREEN" "$C_RESET" "$failed_logins"

printf "\nSystem is %s%s%s\n" "$C_GREEN" "$uptime_str" "$C_RESET"

if [ -n "$updates_total" ] || [ -n "$updates_security" ]; then
	printf "\n"
	[ -n "$updates_total" ] && printf "%s\n" "$updates_total"
	[ -n "$updates_security" ] && printf "%s%s%s\n" "$C_WARN" "$updates_security" "$C_RESET"
fi
